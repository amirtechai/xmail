# Application
APP_ENV=development
DEBUG=false
LOG_LEVEL=INFO
LOG_FORMAT=json

# Database
DATABASE_URL=postgresql+asyncpg://xmail_user:xmail_password@postgres:5432/xmail_db

# Redis
REDIS_URL=redis://redis:6379/0

# Security
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# Admin (Initial User — set password hash via: python -c "from passlib.context import CryptContext; print(CryptContext(schemes=['bcrypt']).hash('yourpassword'))")
ADMIN_EMAIL=patron@amirtech.ai
ADMIN_PASSWORD_HASH=

# LLM Providers (populated from dashboard)
OPENROUTER_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
ZAI_API_KEY=
GROQ_API_KEY=

# Scraping
FIRECRAWL_API_KEY=
PROXY_POOL_URL=
USER_AGENT_ROTATION=true
PLAYWRIGHT_HEADLESS=true

# Email Sending (populated from dashboard)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_NAME=PriceONN Outreach
SMTP_FROM_EMAIL=
COMPANY_PHYSICAL_ADDRESS=

# Compliance & Scheduling
UNSUBSCRIBE_BASE_URL=https://xmail.amirtech.ai/u
TIMEZONE=Europe/Istanbul
DAILY_REPORT_HOUR=9
DAILY_REPORT_MINUTE=0

# Deployment
DOMAIN=xmail.amirtech.ai
FRONTEND_URL=https://xmail.amirtech.ai
API_URL=https://xmail.amirtech.ai/api

# Optional: Monitoring
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=
