# ── Domain & TLS ──────────────────────────────────────────────────────────────
DOMAIN=xmail.amirtech.ai
ACME_EMAIL=info@amirtech.ai

# ── Database ──────────────────────────────────────────────────────────────────
DB_PASSWORD=change-me-strong-db-password-32chars

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=change-me-strong-redis-password

# ── Application secrets ───────────────────────────────────────────────────────
# Generate: openssl rand -hex 32
SECRET_KEY=change-me-generate-with-openssl-rand-hex-32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Admin user (created on first run) ─────────────────────────────────────────
FIRST_ADMIN_EMAIL=admin@yourdomain.com
FIRST_ADMIN_PASSWORD=change-me-strong-admin-password

# ── Grafana ───────────────────────────────────────────────────────────────────
GRAFANA_ADMIN_PASSWORD=change-me-strong-grafana-password

# ── Flower basic auth (htpasswd format) ──────────────────────────────────────
# Generate: echo $(htpasswd -nb admin yourpassword) | sed -e s/\\$/\\$\\$/g
FLOWER_BASIC_AUTH=admin:$$apr1$$xxxx$$yyyy

# ── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Email encryption key ─────────────────────────────────────────────────────
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=change-me-generate-with-fernet

# ── TOTP issuer ───────────────────────────────────────────────────────────────
TOTP_ISSUER=Xmail

# ── Hunter.io (optional — contact enrichment) ─────────────────────────────────
HUNTER_API_KEY=

# ── ZeroBounce (optional — bulk email validation) ────────────────────────────
ZEROBOUNCE_API_KEY=
